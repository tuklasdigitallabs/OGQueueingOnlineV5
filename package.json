{
  "name": "qsys-standalone",
  "version": "1.0.0",
  "description": "QSys Online Display Agent",
  "main": "electron/main.js",
  "author": "One Gourmet Foods Inc.",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "electron .",
    "start:server": "node server/start.js",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run dist:win",
    "prepare:ffmpeg:win": "powershell -ExecutionPolicy Bypass -File scripts/prepare_ffmpeg_windows.ps1",
    "dist:win": "npm run prepare:ffmpeg:win && electron-builder --win",
    "seed:today": "node server/seed-demo-today.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.5.0",
    "dayjs": "^1.11.13",
    "express": "^4.21.2",
    "express-session": "^1.18.2",
    "helmet": "^8.1.0",
    "multer": "^1.4.5-lts.2",
    "node-fetch": "^3.3.2",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.2",
    "socket.io-client": "^4.8.2"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9"
  },
  "overrides": {
    "qs": "^6.14.1"
  },
  "build": {
    "appId": "com.onegourmet.qsysonline",
    "productName": "QSys Online",
    "copyright": "Copyright © One Gourmet Foods Inc.",
    "artifactName": "QSys Display Agent Setup ${version}.${ext}",
    "asar": true,
    "files": [
      "electron/**/*",
      "vendor/ffmpeg/win/**/*",
      "server/**/*.js",
      "server/**/*.sql",
      "server/static/**/*",
      "server/public/assets/icons/**/*",
      "!server/docs{,/**/*}",
      "!server/data{,/**/*}",
      "!server/static/admin_working counters",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "vendor/ffmpeg/win",
        "to": "ffmpeg",
        "filter": [
          "ffmpeg.exe",
          "LICENSE*",
          "README*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "server/public/assets/icons/Yakiniku-Like-logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "server/public/assets/icons/Yakiniku-Like-logo.ico",
      "uninstallerIcon": "server/public/assets/icons/Yakiniku-Like-logo.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "QSys Online"
    }
  }
}
